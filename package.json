{
  "name": "nikibhavi",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "homepage": "https://nikibhavi.msdevbuild.com",
  "scripts": {
    "dev":       "vite",
    "build":     "vite build",
    "preview":   "vite preview",
    "predeploy": "npm run build && echo nikibhavi.msdevbuild.com > dist/CNAME && touch dist/.nojekyll",
    "deploy":    "gh-pages -d dist -b gh-pages",
    "mobile":               "cd mobile && npm install && expo start",
    "mobile:android":       "cd mobile && expo start --android",
    "mobile:ios":           "cd mobile && expo start --ios",
    "mobile:build:android": "cd mobile && eas build --platform android",
    "mobile:build:ios":     "cd mobile && eas build --platform ios"
  },
  "dependencies": {
    "react":            "^18.3.1",
    "react-dom":        "^18.3.1",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "gh-pages":             "^6.1.1",
    "vite":                 "^5.0.0"
  }
}
